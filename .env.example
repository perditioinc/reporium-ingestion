# GitHub API (required)
GH_TOKEN=your_github_personal_access_token
GH_USERNAME=perditioinc

# reporium-api connection (required — or loaded from GCP Secret Manager)
REPORIUM_API_URL=https://reporium-api-573778300586.us-central1.run.app
REPORIUM_API_KEY=

# Claude API for enrichment (required — or loaded from GCP Secret Manager as anthropic-api-key)
ANTHROPIC_API_KEY=
ENRICHMENT_MODEL=claude-sonnet-4-20250514

# Embeddings (local sentence-transformers, free — runs on CPU)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Database (loaded from GCP Secret Manager as reporium-db-url if not set)
DATABASE_URL=

# Rate limit safety
MIN_RATE_LIMIT_BUFFER=100
MAX_CONCURRENCY=2
REQUEST_DELAY_MS=500

# Cache
CACHE_DB_PATH=./data/cache.db
