# GitHub API access
GH_TOKEN=your_github_personal_access_token
GH_USERNAME=perditioinc

# reporium-api connection
REPORIUM_API_URL=https://reporium-api-573778300586.us-central1.run.app
REPORIUM_API_KEY=
INGEST_API_KEY=

# Claude enrichment
ANTHROPIC_API_KEY=
ENRICHMENT_MODEL=claude-sonnet-4-20250514

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional local DB/cache
DATABASE_URL=
CACHE_DB_PATH=./data/cache.db

# GitHub rate-limit safety
MIN_RATE_LIMIT_BUFFER=100
MAX_CONCURRENCY=2
REQUEST_DELAY_MS=500

# Pub/Sub publisher
PUBSUB_REPO_INGESTED_TOPIC=

# Knowledge graph snapshot publication
GRAPH_SNAPSHOT_BUCKET=
GRAPH_SNAPSHOT_OBJECT=reporium/graph/knowledge-graph.json
GRAPH_SNAPSHOT_LOCAL_PATH=

# CLI defaults
DEFAULT_RUN_MODE=quick
