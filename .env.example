# GitHub API (required)
GH_TOKEN=your_github_personal_access_token
GH_USERNAME=perditioinc

# reporium-api connection (required)
REPORIUM_API_URL=http://localhost:8000
REPORIUM_API_KEY=your_ingestion_api_key

# Local AI (optional — degrades gracefully if not available)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text

# Run mode defaults
DEFAULT_RUN_MODE=quick
QUICK_SCHEDULE=0 9 * * *
WEEKLY_SCHEDULE=0 2 * * 0
FULL_SCHEDULE=0 3 1 * *

# Rate limit safety
MIN_RATE_LIMIT_BUFFER=100
MAX_CONCURRENCY=2
REQUEST_DELAY_MS=500

# Cache
CACHE_DB_PATH=./data/cache.db
