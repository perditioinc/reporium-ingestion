FROM python:3.11-slim

WORKDIR /app

# System deps:
#  - gh CLI: enrich_new_repos.py shells out to `gh repo list perditioinc` and
#    `gh auth token` (see scripts/enrich_new_repos.py Phase 0).
#  - curl/ca-certificates/gnupg: required for the GitHub apt signing key install.
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl ca-certificates gnupg \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# Python deps: full requirements.txt because enrichment needs
# sentence-transformers (Phase 4 embeddings) and httpx.
#
# psycopg2-binary, anthropic, and google-cloud-secret-manager are NOT in
# requirements.txt because the wider ingestion library uses aiosqlite and
# doesn't need them. The legacy GH Actions workflow installed them inline
# (see .github/workflows/nightly_enrichment.yml line 105 pre-migration);
# we install them here explicitly for the enrichment job only.
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt \
    && pip install --no-cache-dir anthropic google-cloud-secret-manager psycopg2-binary

# Source: the two scripts the nightly workflow executes end-to-end, plus the
# supporting ingestion/ package and build_knowledge_graph.py (Phase 5).
COPY ingestion/ ingestion/
COPY scripts/ scripts/

ENV PYTHONPATH=/app \
    PYTHONUNBUFFERED=1

# Default entrypoint matches the live Cloud Run Job configuration. The
# previous CMD pointed at `scripts/enrich_new_repos.py` which was deleted
# in KAN-203 PR #82 ("replaced by ingestion.main per KAN-199"); the
# deployed job already overrides via `args=["-m", "ingestion", "run",
# "--mode", "quick"]` (verified 2026-05-12), but the orphan CMD was
# misleading documentation. Override at execute time via
# `gcloud run jobs execute --args=...` for ad-hoc runs.
CMD ["python", "-m", "ingestion", "run", "--mode", "quick"]
